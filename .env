# Crea una aplicación en Autodesk Platform Services y coloca aquí sus credenciales.
APS_CLIENT_ID=REEMPLAZAR_CLIENT_ID
APS_CLIENT_SECRET=REEMPLAZAR_CLIENT_SECRET

# Opcional. Debe ser único globalmente, en minúsculas y sin espacios.
# Si se omite, la aplicación crea uno a partir del Client ID.
APS_BUCKET=

PORT=8080
